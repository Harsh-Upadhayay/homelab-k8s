# Copy this to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit real credentials.

# A Tailscale MagicDNS name (e.g. https://pve-dell.<tailnet>.ts.net:8006/) is
# preferred over a LAN IP so `terraform apply` works from any tailnet device,
# not just one with LAN reachability. The self-signed cert won't match that
# name, but provider.tf sets insecure = true, so that's fine.
proxmox_endpoint  = "https://192.168.1.10:8006/"
proxmox_api_token = "terraform@pve!tf=00000000-0000-0000-0000-000000000000"
proxmox_node      = "pve"

network_gateway = "192.168.1.1"
dns_servers     = ["1.1.1.1", "1.0.0.1"]

ssh_public_key = "ssh-ed25519 AAAA...your-public-key... homelab-admin"
vm_user        = "harsh"

# --- node specs, passed explicitly (variables.tf defaults are fallback docs) ---
server_ip        = "192.168.1.21"
server_cores     = 4
server_memory    = 6144
server_disk_size = 60

worker_ip             = "192.168.1.22"
worker2_ip            = "192.168.1.23"
worker_cores          = 6
worker_memory         = 9216
worker_disk_size      = 60
worker_data_disk_size = 280
