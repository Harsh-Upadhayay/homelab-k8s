# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
# terraform.tfvars is intentionally NOT ignored — it holds no secrets (the API
# token comes from PROXMOX_VE_API_TOKEN at runtime), so it's committed as the
# source of truth for this host.

# Ansible
ansible/*.retry
.env

# Kubeconfig pulled from the cluster
kubeconfig
*.kubeconfig

# Stray shell redirect artifacts at repo root (caught one holding a live
# OAuth client secret - never intentional, never meant to be tracked)
/*.log

# Claude Code worktrees (EnterWorktree) - local scratch checkouts, never meant
# to be tracked as gitlinks in the main repo's history
.claude/worktrees/
